# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.

# Django
SECRET_KEY=django-insecure-cambia-esta-clave-en-produccion
DEBUG=True
ALLOWED_HOSTS=*

# Base de datos (MySQL producción)
DB_NAME=toxirin$gymdb
DB_USER=toxirin
DB_PASSWORD=
DB_HOST=toxirin.mysql.pythonanywhere-services.com
DB_PORT=3306

# Google Gemini AI
GEMINI_API_KEY=

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Notificaciones push (FCM)
PUSH_NOTIFICATION_KEY=
